NODE_ENV=development
HOST=localhost
PORT=3000
# CORS
CORS_ORIGIN=http://localhost:5173
# Rate Limit
COMMON_RATE_LIMIT_MAX_REQUESTS=1000
COMMON_RATE_LIMIT_WINDOW_MS=60000
# Database URL (Prisma)
# For Docker Compose, use: postgresql://postgres:postgres@db:5432/app?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?schema=public
# Redis — optional: IP rate limits for POST /orders/track/check-phone and /orders/track/verify-phone-auth
REDIS_URL=redis://localhost:6379
ORDER_TRACK_OTP_MAX_REQUESTS=10
ORDER_TRACK_OTP_RATE_LIMIT_WINDOW_SEC=86400
# Allow POST /orders/track/verify-phone-auth with bypassAuth+phone (also allowed when NODE_ENV=development)
ORDER_TRACK_BYPASS_AUTH=false

# Product views: buffered in Redis (POST /products/:id/views), flushed to DB every PRODUCT_VIEW_FLUSH_INTERVAL_MS
PRODUCT_VIEW_PREVENT_DUPLICATE=false
PRODUCT_VIEW_DEDUPE_TTL_SEC=60
PRODUCT_VIEW_FLUSH_INTERVAL_MS=60000
PRODUCT_VIEW_FLUSH_LOCK_TTL_SEC=120

# Expired stock reservations: released on interval while the server run
RELEASE_EXPIRED_RESERVATIONS_INTERVAL_MS=120000
RELEASE_EXPIRED_RESERVATIONS_BATCH_SIZE=100
# true = reservations have no expires_at (until you set ALLOW_UNLIMITED_RESERVATION=false)
ALLOW_UNLIMITED_RESERVATION=true

# Firebase Admin — verify Phone Auth ID tokens (JSON string of service account, or use ADC)
FIREBASE_SERVICE_ACCOUNT_JSON=
# AWS
AWS_REGION=your-region
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_CLOUDFRONT_BASE_URL=https://your-cloudfront-base-url
S3_BUCKET=your-s3-bucket
S3_PRESIGNED_EXPIRES_IN=900

# JWT (auth)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Outbound email (order notifications). Leave SMTP_HOST empty to skip sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME=Cửa hàng Sticker
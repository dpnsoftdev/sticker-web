{
  "name": "shared-dango-blog-editor",
  "version": "0.1.0",
  "description": "Reusable Tiptap blog editor (React) for Dango — no app-specific business logic",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/dango-blog-editor.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./dango-blog-editor.css": "./dist/dango-blog-editor.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/dango-blog-editor.css dist/dango-blog-editor.css",
    "start": "vite --config vite.playground.mts",
    "dev": "vite --config vite.playground.mts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/html": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
